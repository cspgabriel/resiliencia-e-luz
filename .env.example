# VITE_OPENROUTER_API_KEY=

# Pagamento (Fase 2)
# VITE_STRIPE_PUBLIC_KEY=
# VITE_MERCADOPAGO_PUBLIC_KEY=

# Backend Worker (Fase 2)
# VITE_API_URL=https://serenamente-api.workers.dev
