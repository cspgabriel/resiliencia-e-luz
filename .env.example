# Serenamente - configuração local
# IMPORTANTE: NUNCA exponha chave de IA em produção. Em prod, use backend proxy.

# Backend Worker / Proxy de IA
VITE_AI_PROXY_URL=/api/chat

# Somente desenvolvimento local. Mantém fallback direto no client quando explicitamente ativado.
VITE_ALLOW_CLIENT_AI_DEV=false
VITE_GEMINI_API_KEY=

# Pagamento (Fase 2)
# Web/PWA: Stripe ou Mercado Pago quando permitido.
# Apps nativos: usar App Store In-App Purchase / Google Play Billing para bens digitais.
# VITE_STRIPE_PUBLIC_KEY=
# VITE_MERCADOPAGO_PUBLIC_KEY=

# Backend Worker em produção
# VITE_AI_PROXY_URL=https://serenamente-api.workers.dev/api/chat

# ===== Firebase (Web SDK - chaves PÚBLICAS, podem ir pro client) =====
# Pegue em: Firebase Console > Configurações do Projeto > Seus apps > Web
VITE_FIREBASE_API_KEY=AIzaSyC7Sqm4Ov3-8u1B4AUauG8u-XFe8i6rjAw
VITE_FIREBASE_AUTH_DOMAIN=primeval-jet-326417.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=primeval-jet-326417
VITE_FIREBASE_STORAGE_BUCKET=primeval-jet-326417.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=210642716
VITE_FIREBASE_APP_ID=1:210642716:web:aa16be228ff02502b4bcd9
# Opcional - analytics web
VITE_FIREBASE_MEASUREMENT_ID=

# ===== Firebase Admin (APENAS no Worker - NUNCA expor ao client) =====
# No Cloudflare Worker: configure via `wrangler secret put FIREBASE_SERVICE_ACCOUNT`
# Conteúdo: JSON inteiro do service account em uma única linha
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ===== Google AdSense =====
# Sem essa chave, o app mostra "house ads" (promove o Plus).
# Pegue em https://www.google.com/adsense → conta → ID do editor (formato: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_CLIENT=
